#include <dt-bindings/zmk/matrix_transform.h>
#include <physical_layouts.dtsi>

/ {
	chosen {
		zmk,physical-layout = &cleave_hhjp_physical_layout;
	};

	cleave_hhjp_physical_layout: cleave_hhjp_physical_layout {
		compatible = "zmk,physical-layout";
		display-name = "Cleave HHJP";
		transform = <&default_transform>;
		kscan = <&kscan0>;

		keys  // 70 keys: width, height, x, y, r, rx, ry (in centi-keyunits, 1U = 100)
			// Row 0: ESC + 6 keys (left) + gap 2U + 8 keys (right)
			= <&key_physical_attrs 100 100   0   0 0 0 0>  // ESC
			, <&key_physical_attrs 100 100 100   0 0 0 0>  // 1
			, <&key_physical_attrs 100 100 200   0 0 0 0>  // 2
			, <&key_physical_attrs 100 100 300   0 0 0 0>  // 3
			, <&key_physical_attrs 100 100 400   0 0 0 0>  // 4
			, <&key_physical_attrs 100 100 500   0 0 0 0>  // 5
			, <&key_physical_attrs 100 100 600   0 0 0 0>  // 6
			, <&key_physical_attrs 100 100 800   0 0 0 0>  // 7 (gap 2U = 200)
			, <&key_physical_attrs 100 100 900   0 0 0 0>  // 8
			, <&key_physical_attrs 100 100 1000  0 0 0 0>  // 9
			, <&key_physical_attrs 100 100 1100  0 0 0 0>  // 0
			, <&key_physical_attrs 100 100 1200  0 0 0 0>  // -
			, <&key_physical_attrs 100 100 1300  0 0 0 0>  // ^
			, <&key_physical_attrs 100 100 1400  0 0 0 0>  // ¥
			, <&key_physical_attrs 100 100 1500  0 0 0 0>  // BS
			// Row 1: Tab(1.5U) + 5 keys (left) + gap 2U + 7 keys + Enter(1.25U×2h) (right)
			, <&key_physical_attrs 150 100   0 100 0 0 0>  // Tab (1.5U = 150)
			, <&key_physical_attrs 100 100 150 100 0 0 0>  // Q
			, <&key_physical_attrs 100 100 250 100 0 0 0>  // W
			, <&key_physical_attrs 100 100 350 100 0 0 0>  // E
			, <&key_physical_attrs 100 100 450 100 0 0 0>  // R
			, <&key_physical_attrs 100 100 550 100 0 0 0>  // T
			, <&key_physical_attrs 100 100 800 100 0 0 0>  // Y (gap 2U)
			, <&key_physical_attrs 100 100 900 100 0 0 0>  // U
			, <&key_physical_attrs 100 100 1000 100 0 0 0> // I
			, <&key_physical_attrs 100 100 1100 100 0 0 0> // O
			, <&key_physical_attrs 100 100 1200 100 0 0 0> // P
			, <&key_physical_attrs 100 100 1300 100 0 0 0> // @
			, <&key_physical_attrs 100 100 1400 100 0 0 0> // [
			, <&key_physical_attrs 125 200 1500 100 0 0 0> // Enter (1.25U×2h)
			// Row 2: Ctrl(1.75U) + 5 keys (left) + gap 2U + 7 keys (right)
			, <&key_physical_attrs 175 100   0 200 0 0 0>  // Ctrl (1.75U = 175)
			, <&key_physical_attrs 100 100 175 200 0 0 0>  // A
			, <&key_physical_attrs 100 100 275 200 0 0 0>  // S
			, <&key_physical_attrs 100 100 375 200 0 0 0>  // D
			, <&key_physical_attrs 100 100 475 200 0 0 0>  // F
			, <&key_physical_attrs 100 100 575 200 0 0 0>  // G
			, <&key_physical_attrs 100 100 800 200 0 0 0>  // H (gap 2U)
			, <&key_physical_attrs 100 100 900 200 0 0 0>  // J
			, <&key_physical_attrs 100 100 1000 200 0 0 0> // K
			, <&key_physical_attrs 100 100 1100 200 0 0 0> // L
			, <&key_physical_attrs 100 100 1200 200 0 0 0> // ;
			, <&key_physical_attrs 100 100 1300 200 0 0 0> // :
			, <&key_physical_attrs 100 100 1400 200 0 0 0> // ]
			// Row 3: LShift(2U) + 5 keys (left) + gap 2U + 6 keys + Up + RShift (right)
			, <&key_physical_attrs 200 100   0 300 0 0 0>  // LShift (2U = 200)
			, <&key_physical_attrs 100 100 200 300 0 0 0>  // Z
			, <&key_physical_attrs 100 100 300 300 0 0 0>  // X
			, <&key_physical_attrs 100 100 400 300 0 0 0>  // C
			, <&key_physical_attrs 100 100 500 300 0 0 0>  // V
			, <&key_physical_attrs 100 100 600 300 0 0 0>  // B
			, <&key_physical_attrs 100 100 800 300 0 0 0>  // N (gap 2U)
			, <&key_physical_attrs 100 100 900 300 0 0 0>  // M
			, <&key_physical_attrs 100 100 1000 300 0 0 0> // <
			, <&key_physical_attrs 100 100 1100 300 0 0 0> // >
			, <&key_physical_attrs 100 100 1200 300 0 0 0> // /
			, <&key_physical_attrs 100 100 1300 300 0 0 0> // _
			, <&key_physical_attrs 100 100 1400 300 0 0 0> // Up
			, <&key_physical_attrs 100 100 1500 300 0 0 0> // RShift
			// Row 4: Fn + gap 0.25U + 4 keys + Space(1.25U) (left) + gap 2U + Space(1.25U) + 3 keys + gap 0.25U + 3 arrows (right)
			, <&key_physical_attrs 100 100   0 400 0 0 0>  // Fn
			, <&key_physical_attrs 100 100 125 400 0 0 0>  // Win (gap 0.25U = 25)
			, <&key_physical_attrs 100 100 225 400 0 0 0>  // Cmd
			, <&key_physical_attrs 100 100 325 400 0 0 0>  // Alt
			, <&key_physical_attrs 100 100 425 400 0 0 0>  // E/J
			, <&key_physical_attrs 125 100 525 400 0 0 0>  // Space L (1.25U = 125)
			, <&key_physical_attrs 125 100 800 400 0 0 0>  // Space R (gap 2U, 1.25U)
			, <&key_physical_attrs 100 100 925 400 0 0 0>  // E/J
			, <&key_physical_attrs 100 100 1025 400 0 0 0> // Kana
			, <&key_physical_attrs 100 100 1125 400 0 0 0> // Alt
			, <&key_physical_attrs 100 100 1225 400 0 0 0> // Fn
			, <&key_physical_attrs 100 100 1350 400 0 0 0> // Left (gap 0.25U)
			, <&key_physical_attrs 100 100 1450 400 0 0 0> // Down
			, <&key_physical_attrs 100 100 1550 400 0 0 0> // Right
			;
	};

	default_transform: keymap_transform_0 {
		compatible = "zmk,matrix-transform";
		columns = <15>;
		rows = <5>;

		map = <
			RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5) RC(0,6)   RC(0,7) RC(0,8) RC(0,9) RC(0,10) RC(0,11) RC(0,12) RC(0,13) RC(0,14)
			RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)           RC(1,7) RC(1,8) RC(1,9) RC(1,10) RC(1,11) RC(1,12) RC(1,13) RC(1,14)
			RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)           RC(2,7) RC(2,8) RC(2,9) RC(2,10) RC(2,11) RC(2,12) RC(2,13)
			RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)           RC(3,7) RC(3,8) RC(3,9) RC(3,10) RC(3,11) RC(3,12) RC(3,13) RC(3,14)
			RC(4,0) RC(4,1) RC(4,2) RC(4,3) RC(4,4) RC(4,5)           RC(4,7) RC(4,8) RC(4,9) RC(4,10) RC(4,11) RC(4,12) RC(4,13) RC(4,14)
		>;
	};

	kscan0: kscan_0 {
		compatible = "zmk,kscan-gpio-matrix";
		label = "KSCAN";
		diode-direction = "col2row";
	};
};
